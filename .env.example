# ─────────────────────────────────────────────────────────────
# Open Beauchef OS — variables de entorno (frontend / Vite)
# Copia este archivo a .env y ajusta lo que necesites.
# TODO es opcional: la app funciona sin ninguna variable (modo demo).
# ─────────────────────────────────────────────────────────────

# ── Backend Financial Copilot (opcional) ─────────────────────
# El frontend funciona con datos demo si el backend no está.
VITE_API_BASE=http://localhost:3000
VITE_DEMO_EMAIL=paloma@decantopia.cl
VITE_DEMO_PASSWORD=paloma1234

# ── IA (AI Discovery) ────────────────────────────────────────
# Proveedor por defecto: ollama. Fallback automático a "mock" si no responde.
# Alternativas futuras (claude, openai, gemini) se agregan sin tocar la UI.
VITE_AI_PROVIDER=ollama
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2

# ── Open Banking (Fintoc) ────────────────────────────────────
# Si falta cualquiera, la app usa Carga Manual (CSV) automáticamente.
# Frontend (seguro de exponer): public key + habilitar.
VITE_FINTOC_ENABLED=false
VITE_FINTOC_PUBLIC_KEY=pk_live_o_test_...
# Endpoint de las funciones serverless incluidas (déjalo así en Vercel).
VITE_FINTOC_LINK_ENDPOINT=/api/fintoc
#
# SERVIDOR (NUNCA con prefijo VITE_, nunca en el frontend):
# Configúrala en Vercel → Project → Settings → Environment Variables.
FINTOC_SECRET_KEY=sk_live_o_test_...

# ── Notificaciones ───────────────────────────────────────────
# browser = notificaciones de escritorio (default). Sin WhatsApp aún.
VITE_NOTIFY_PROVIDER=browser

# ── Persistencia ─────────────────────────────────────────────
# local = LocalStorage (default). firebase = stub preparado para el futuro.
VITE_PERSISTENCE=local

# ── Autenticación ────────────────────────────────────────────
# local = sesión en LocalStorage. firebase = Firebase Auth (multi-dispositivo).
VITE_AUTH_PROVIDER=local

# ── Firebase (opcional; activa datos por cuenta + vista admin) ─
# Si defines estas variables Y VITE_AUTH_PROVIDER=firebase y VITE_PERSISTENCE
# se mantienen coherentes, la app guarda cada emprendedor en Firestore y
# sincroniza entre dispositivos. Si las dejas vacías, todo sigue en LocalStorage.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Emails con acceso al panel /admin (tu jefe). Separados por coma.
VITE_ADMIN_EMAILS=jefe@openbeauchef.cl
# Emails de mentores con acceso a /mentor. Separados por coma.
VITE_MENTOR_EMAILS=mentor@openbeauchef.cl
